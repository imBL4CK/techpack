		{
			dependencies: ["720CC28CC9F618B8"]
			description: [
				"Makeshift mechanisms are the first crafting components. They are used in basic crafts during the early stages."
				""
				"&e-&r At first, you will have to craft them manually using the smithing table. Later on, you can automate their production through the sequenced assembly process."
			]
			id: "708D8EA7F48BBCC9"
			rewards: [{
				id: "5BB9E202819DD1A2"
				item: "kubejs:common_techbuck"
